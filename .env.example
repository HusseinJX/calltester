# Server
PORT=3000

# Anthropic API Key (for AI responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI Model (optional, defaults to claude-sonnet-4-20250514)
AI_MODEL=claude-sonnet-4-20250514

# Twilio Voice (optional - see https://www.twilio.com/docs/voice/twiml/say#voice)
# Options: Polly.Matthew, Polly.Joanna, Polly.Amy, Polly.Brian, etc.
VOICE=Polly.Matthew

# Tester Persona (optional - customize how the tester behaves)
TESTER_PERSONA="You are a potential customer interested in learning about products and services. Be friendly but ask clarifying questions. Keep responses brief."

# Initial greeting when call connects (optional)
INITIAL_GREETING="Hello?"
